{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bansuri:scripts.schema.json",
  "title": "Bansuri Script Scheduler Config",
  "type": "object",
  "required": ["version", "scripts"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scheduling": {
          "$ref": "#/$defs/partialScheduling"
        },
        "failure-control": {
          "$ref": "#/$defs/partialFailureControl"
        },
        "logging": {
          "$ref": "#/$defs/partialLogging"
        }
      }
    },
    "scripts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/script"
      }
    }
  },
  "$defs": {
    "script": {
      "type": "object",
      "required": ["general", "scheduling", "failure-control", "logging"],
      "additionalProperties": false,
      "properties": {
        "general": {
          "$ref": "#/$defs/general"
        },
        "scheduling": {
          "$ref": "#/$defs/scheduling"
        },
        "failure-control": {
          "$ref": "#/$defs/failureControl"
        },
        "logging": {
          "$ref": "#/$defs/logging"
        }
      }
    },

    "general": {
      "type": "object",
      "required": ["name", "command"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "working-directory": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "scheduling": {
      "type": "object",
      "required": ["scheduler"],
      "additionalProperties": false,
      "properties": {
        "scheduler": {
          "type": "string",
          "enum": ["none", "timer", "cron"]
        },
        "params": {
          "type": "string"
        },
        "timeout": {
          "$ref": "#/$defs/duration"
        },
        "max-runs": {
          "$ref": "#/$defs/nonNegativeIntegerLike"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scheduler": {
                "const": "cron"
              }
            },
            "required": ["scheduler"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/$defs/cronExpression"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scheduler": {
                "const": "timer"
              }
            },
            "required": ["scheduler"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/$defs/timerParam"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scheduler": {
                "const": "none"
              }
            },
            "required": ["scheduler"]
          },
          "then": {
            "properties": {
              "params": {
                "const": "0"
              }
            }
          }
        }
      ]
    },

    "partialScheduling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scheduler": {
          "type": "string",
          "enum": ["none", "timer", "cron"]
        },
        "params": {
          "type": "string"
        },
        "timeout": {
          "$ref": "#/$defs/duration"
        },
        "max-runs": {
          "$ref": "#/$defs/nonNegativeIntegerLike"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scheduler": {
                "const": "cron"
              }
            },
            "required": ["scheduler"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/$defs/cronExpression"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scheduler": {
                "const": "timer"
              }
            },
            "required": ["scheduler"]
          },
          "then": {
            "required": ["params"],
            "properties": {
              "params": {
                "$ref": "#/$defs/timerParam"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scheduler": {
                "const": "none"
              }
            },
            "required": ["scheduler"]
          },
          "then": {
            "properties": {
              "params": {
                "const": "0"
              }
            }
          }
        }
      ]
    },

    "failureControl": {
      "type": "object",
      "required": ["on-fail"],
      "additionalProperties": false,
      "properties": {
        "on-fail": {
          "type": "string",
          "enum": ["ignore", "stop", "restart"]
        },
        "max-attempts": {
          "$ref": "#/$defs/nonNegativeIntegerLike"
        },
        "restart-params": {
          "$ref": "#/$defs/restartParams"
        },
        "notify": {
          "$ref": "#/$defs/notify"
        }
      }
    },

    "partialFailureControl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "on-fail": {
          "type": "string",
          "enum": ["ignore", "stop", "restart"]
        },
        "max-attempts": {
          "$ref": "#/$defs/nonNegativeIntegerLike"
        },
        "restart-params": {
          "$ref": "#/$defs/restartParams"
        },
        "notify": {
          "$ref": "#/$defs/partialNotify"
        }
      }
    },

    "restartParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "after": {
          "$ref": "#/$defs/duration"
        },
        "after-scheduling": {
          "type": "string",
          "enum": ["none", "dynamic-linear", "dynamic"]
        },
        "after-step": {
          "$ref": "#/$defs/positiveNumberLike"
        }
      }
    },

    "notify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "$ref": "#/$defs/booleanLike"
        },
        "mode": {
          "type": "string",
          "enum": ["on-exhausted", "after-fail", "after-many"]
        },
        "after-threshold": {
          "$ref": "#/$defs/positiveIntegerLike"
        },
        "handler": {
          "type": "string",
          "enum": ["command", "python", "json"]
        },
        "handler-config": {
          "type": ["string", "object"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "after-many"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["after-threshold"]
          }
        }
      ]
    },

    "partialNotify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "$ref": "#/$defs/booleanLike"
        },
        "mode": {
          "type": "string",
          "enum": ["on-exhausted", "after-fail", "after-many"]
        },
        "after-threshold": {
          "$ref": "#/$defs/positiveIntegerLike"
        },
        "handler": {
          "type": "string",
          "enum": ["command", "python", "json"]
        },
        "handler-config": {
          "type": ["string", "object"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "after-many"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "required": ["after-threshold"]
          }
        }
      ]
    },

    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stdout": {
          "$ref": "#/$defs/logTarget"
        },
        "stderr": {
          "$ref": "#/$defs/logTarget"
        }
      }
    },

    "partialLogging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stdout": {
          "$ref": "#/$defs/logTarget"
        },
        "stderr": {
          "$ref": "#/$defs/logTarget"
        }
      }
    },

    "duration": {
      "type": "string",
      "pattern": "^[1-9][0-9]*(ms|s|m|h|d)$"
    },

    "timerParam": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*(ms|s|m|h|d))$"
    },

    "cronExpression": {
      "type": "string",
      "pattern": "^(@(annually|yearly|monthly|weekly|daily|hourly|reboot)|\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+)$"
    },

    "logTarget": {
      "type": "string",
      "anyOf": [
        {
          "const": "$$combined"
        },
        {
          "const": "ignore"
        },
        {
          "minLength": 1
        }
      ]
    },

    "booleanLike": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string",
          "enum": ["true", "false"]
        }
      ]
    },

    "nonNegativeIntegerLike": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      ]
    },

    "positiveIntegerLike": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        }
      ]
    },

    "positiveNumberLike": {
      "anyOf": [
        {
          "type": "number",
          "exclusiveMinimum": 0
        },
        {
          "type": "string",
          "pattern": "^(0\\.[0-9]+|[1-9][0-9]*(\\.[0-9]+)?)$"
        }
      ]
    }
  }
}
